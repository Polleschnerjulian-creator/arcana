generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Tenant Core ────────────────────────────────────────────

model Organization {
  id                String   @id @default(cuid())
  name              String
  legalForm         String   // EU, GmbH, UG, AG, OHG, KG, GbR, FreiBeruf
  taxId             String?  // Steuernummer
  ustId             String?  // USt-IdNr.
  street            String?
  city              String?
  zip               String?
  country           String   @default("DE")
  chartOfAccounts   String   @default("SKR03") // SKR03 | SKR04
  accountingMethod  String   @default("EUR")   // EUR | BILANZ
  fiscalYearStart   Int      @default(1) // Month (1-12)
  settings          String?  // JSON string for preferences
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  accounts          Account[]
  transactions      Transaction[]
  documents         Document[]
  bankAccounts      BankAccount[]
  taxPeriods        TaxPeriod[]
  auditLogs         AuditLog[]
  invoices          Invoice[]
  apiKeys           ApiKey[]
  webhookLogs       WebhookLog[]
  recurringTemplates RecurringTemplate[]
  categorizationRules CategorizationRule[]
  shopifyConnection ShopifyConnection?
  dunningEntries     DunningEntry[]
  bookingTemplates   BookingTemplate[]
  fixedAssets        FixedAsset[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           String   @default("OWNER") // OWNER | ADMIN | BOOKKEEPER | VIEWER
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  bookedTransactions  Transaction[] @relation("BookedBy")
  uploadedDocuments   Document[]    @relation("UploadedBy")
  auditLogs      AuditLog[]

  @@index([organizationId])
}

// ─── Kontenrahmen (Chart of Accounts) ─────────────────────────────

model Account {
  id             String   @id @default(cuid())
  organizationId String
  number         String   // e.g., "1200" for Bank
  name           String   // e.g., "Bank"
  type           String   // ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  category       String   // ANLAGE | UMLAUF | EIGENKAPITAL | ERLOES | AUFWAND
  parentId       String?
  isSystem       Boolean  @default(false) // true for standard SKR accounts
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  parent         Account?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]    @relation("AccountHierarchy")

  transactionLines TransactionLine[] @relation("LineAccount")
  taxLines         TransactionLine[] @relation("TaxAccount")
  bankAccount    BankAccount?

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, type])
}

// ─── Buchungssatz (Core Transaction) ──────────────────────────────

model Transaction {
  id              String    @id @default(cuid())
  organizationId  String
  date            DateTime  // Buchungsdatum
  description     String    // Buchungstext
  reference       String?   // Belegnummer
  documentId      String?
  status          String    @default("DRAFT") // DRAFT | BOOKED | CANCELLED
  bookedAt        DateTime? // Festschreibung — immutable after set
  bookedById      String?
  cancelledById   String?   @unique // References the Stornobuchung
  source          String    @default("MANUAL") // MANUAL | AI_SUGGESTED | BANK_IMPORT | API
  aiConfidence    Float?    // 0-1, null if manual
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  document        Document?    @relation(fields: [documentId], references: [id])
  bookedBy        User?        @relation("BookedBy", fields: [bookedById], references: [id])
  cancelledBy     Transaction? @relation("StornoRef", fields: [cancelledById], references: [id])
  stornoOf        Transaction? @relation("StornoRef")
  lines           TransactionLine[]
  bankTransactions BankTransaction[]
  invoiceLink     Invoice?     @relation("InvoiceTransaction")

  @@index([organizationId])
  @@index([organizationId, date])
  @@index([organizationId, status])
  @@index([documentId])
}

model TransactionLine {
  id              String  @id @default(cuid())
  transactionId   String
  accountId       String
  debit           Decimal @default(0) // Soll
  credit          Decimal @default(0) // Haben
  taxRate         Float?  // 0, 7, 19, null
  taxAccountId    String?
  note            String?

  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account         Account     @relation("LineAccount", fields: [accountId], references: [id])
  taxAccount      Account?    @relation("TaxAccount", fields: [taxAccountId], references: [id])

  @@index([transactionId])
  @@index([accountId])
}

// ─── Belege (Documents) ───────────────────────────────────────────

model Document {
  id              String   @id @default(cuid())
  organizationId  String
  fileName        String
  mimeType        String
  fileSize        Int
  storagePath     String   // Local path or R2 key
  sha256Hash      String   // GoBD: computed at upload
  uploadedAt      DateTime @default(now())
  uploadedById    String
  ocrText         String?  // Raw OCR output
  ocrStatus       String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  aiExtraction    String?  // JSON: { vendor, amount, taxRate, date, invoiceNumber, lineItems[] }
  type            String   @default("OTHER") // INCOMING_INVOICE | OUTGOING_INVOICE | RECEIPT | BANK_STATEMENT | OTHER

  organization    Organization  @relation(fields: [organizationId], references: [id])
  uploadedBy      User          @relation("UploadedBy", fields: [uploadedById], references: [id])
  transactions    Transaction[]

  @@index([organizationId])
  @@index([sha256Hash])
}

// ─── Bank ─────────────────────────────────────────────────────────

model BankAccount {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  iban            String?
  bic             String?
  accountId       String    @unique // Linked Konto (e.g., 1200)
  lastImportAt    DateTime?
  createdAt       DateTime  @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id])
  account         Account          @relation(fields: [accountId], references: [id])
  bankTransactions BankTransaction[]

  @@index([organizationId])
}

model BankTransaction {
  id                    String   @id @default(cuid())
  bankAccountId         String
  date                  DateTime
  amount                Decimal
  description           String
  counterpartName       String?
  counterpartIban       String?
  importBatch           String   // Groups transactions from same import
  matchedTransactionId  String?
  matchConfidence       Float?   // 0-1
  matchStatus           String   @default("UNMATCHED") // UNMATCHED | AI_SUGGESTED | CONFIRMED | MANUAL
  createdAt             DateTime @default(now())

  bankAccount           BankAccount  @relation(fields: [bankAccountId], references: [id])
  matchedTransaction    Transaction? @relation(fields: [matchedTransactionId], references: [id])

  @@index([bankAccountId])
  @@index([matchStatus])
}

// ─── Steuer (Tax) ─────────────────────────────────────────────────

model TaxPeriod {
  id              String    @id @default(cuid())
  organizationId  String
  type            String    // USTVA_MONTHLY | USTVA_QUARTERLY | ANNUAL
  periodStart     DateTime
  periodEnd       DateTime
  ustAmount       Decimal   @default(0) // Umsatzsteuer
  vstAmount       Decimal   @default(0) // Vorsteuer
  payloadAmount   Decimal   @default(0) // Zahllast
  status          String    @default("OPEN") // OPEN | CALCULATED | FILED
  filedAt         DateTime?
  createdAt       DateTime  @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, type, periodStart])
}

// ─── GoBD Audit Trail ─────────────────────────────────────────────

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String
  timestamp       DateTime @default(now())
  userId          String
  action          String   // CREATE | UPDATE | BOOK | CANCEL | DELETE | EXPORT | LOGIN
  entityType      String   // TRANSACTION | DOCUMENT | ACCOUNT | etc.
  entityId        String
  previousState   String?  // JSON snapshot
  newState        String?  // JSON snapshot
  hashChain       String   // SHA-256(previousHash + currentData)

  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, timestamp])
}

// ─── Ausgangsrechnungen (Outgoing Invoices) ───────────────────────

model Invoice {
  id              String    @id @default(cuid())
  organizationId  String
  invoiceNumber   String    // Auto-generated, sequential
  customerId      String?
  customerName    String
  customerAddress String?
  issueDate       DateTime
  dueDate         DateTime
  status          String    @default("DRAFT") // DRAFT | SENT | PAID | OVERDUE | CANCELLED
  lineItems       String    // JSON array
  subtotal        Decimal
  taxAmount       Decimal
  total           Decimal
  transactionId   String?   @unique // Auto-created on send
  pdfPath         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  transaction     Transaction? @relation("InvoiceTransaction", fields: [transactionId], references: [id])

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

// ─── API Keys (for external integrations) ─────────────────────────

model ApiKey {
  id              String    @id @default(cuid())
  organizationId  String
  name            String    // e.g., "Zapier", "Stripe Webhook", "Billbee"
  keyHash         String    // SHA-256 hash of the key (never store plaintext)
  keyPrefix       String    // First 8 chars for identification (e.g., "arc_ab12...")
  permissions     String    @default("webhook") // webhook | full_read | full_write
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([keyHash])
}

// ─── Webhook Logs ─────────────────────────────────────────────────

model WebhookLog {
  id              String   @id @default(cuid())
  organizationId  String
  source          String   // zapier | stripe | billbee | custom | unknown
  event           String   // invoice.created | document.uploaded | transaction.created
  payload         String   // JSON — raw incoming payload
  status          String   @default("RECEIVED") // RECEIVED | PROCESSED | FAILED
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, source])
  @@index([createdAt])
}

// ─── Recurring Templates ──────────────────────────────────────────

model RecurringTemplate {
  id              String    @id @default(cuid())
  organizationId  String
  type            String    // INVOICE | TRANSACTION
  name            String    // e.g., "Monatliche Büromiete"
  interval        String    // MONTHLY | QUARTERLY | YEARLY
  dayOfMonth      Int       @default(1) // 1-28
  nextRunDate     DateTime
  lastRunDate     DateTime?
  isActive        Boolean   @default(true)
  templateData    String    // JSON — invoice or transaction template
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([nextRunDate, isActive])
}

// ─── Categorization Rules (learning from user corrections) ────────

model CategorizationRule {
  id              String   @id @default(cuid())
  organizationId  String
  vendorPattern   String   // Normalized vendor/counterpart name pattern
  debitAccount    String   // Account number for Soll
  creditAccount   String   // Account number for Haben
  taxRate         Float?   // 0, 7, 19
  confidence      Float    @default(1.0) // User-confirmed = 1.0
  usageCount      Int      @default(1)
  lastUsedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, vendorPattern])
  @@index([organizationId])
}

// ─── Shopify Integration ──────────────────────────────────────────

model ShopifyConnection {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  shopDomain      String   // e.g., "myshop.myshopify.com"
  webhookSecret   String   // HMAC secret for verifying webhooks
  defaultTaxRate  Float    @default(19) // Default tax rate for orders
  isActive        Boolean  @default(true)
  ordersProcessed Int      @default(0)
  lastOrderAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
}

model ShopifyOrder {
  id              String   @id @default(cuid())
  organizationId  String
  shopifyOrderId  String   // Shopify's order ID (e.g., "5678901234")
  shopifyOrderNumber String // Display number (e.g., "#1001")
  invoiceId       String?  // Linked ARCANA invoice
  transactionId   String?  // Linked ARCANA transaction
  status          String   @default("PROCESSED") // PROCESSED | REFUNDED | PARTIAL_REFUND
  orderTotal      Decimal
  currency        String   @default("EUR")
  processedAt     DateTime @default(now())

  @@unique([organizationId, shopifyOrderId])
  @@index([organizationId])
}

// ─── Password Reset ──────────────────────────────────────────────

model PasswordReset {
  id        String    @id @default(cuid())
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([email])
}

// ─── Mahnwesen (Dunning / Payment Reminders) ─────────────────────

model DunningEntry {
  id              String   @id @default(cuid())
  organizationId  String
  invoiceId       String
  level           Int      // 1 = Zahlungserinnerung, 2 = 1. Mahnung, 3 = 2. Mahnung
  sentAt          DateTime @default(now())
  dueDate         DateTime // New due date given in the reminder
  fee             Decimal  @default(0) // Mahngebühr (optional)

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([invoiceId])
}

// ─── Buchungsvorlagen (Booking Templates) ─────────────────────────

model BookingTemplate {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  templateLines   String   // JSON: [{ accountNumber, debit, credit, taxRate? }]
  isDefault       Boolean  @default(false)
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ─── Anlagenbuchhaltung (Fixed Asset Accounting) ─────────────────

model FixedAsset {
  id                 String    @id @default(cuid())
  organizationId     String
  name               String    // e.g., "MacBook Pro 16"
  description        String?
  accountId          String    // Linked Anlage account (e.g., 0320 PKW, 0420 Büro)
  purchaseDate       DateTime
  purchasePrice      Decimal   // Anschaffungskosten
  usefulLifeYears    Int       // Nutzungsdauer in Jahren (AfA-Tabelle)
  depreciationMethod String    @default("LINEAR") // LINEAR | DEGRESSIVE
  residualValue      Decimal   @default(0) // Restwert
  currentBookValue   Decimal   // Aktueller Buchwert
  isActive           Boolean   @default(true) // false = ausgeschieden
  disposalDate       DateTime?
  disposalPrice      Decimal?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}
